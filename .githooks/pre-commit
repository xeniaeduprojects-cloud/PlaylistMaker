#!/bin/sh
set -e

echo "Stashing unstaged changes..."
git stash push --keep-index --quiet -m "pre-format-unstaged"

RESTORE_STASH=0
if git stash list | grep -q "pre-format-unstaged"; then
    RESTORE_STASH=1
fi

echo "Running ktlint format..."
./gradlew ktlintFormat

git add -u

echo "Running ktlint check..."
./gradlew ktlintCheck

echo "Running detekt..."
./gradlew detekt

if ! git diff --cached --quiet; then
    git commit -m "Apply ktlint formatting"
fi

if [ "$RESTORE_STASH" -eq 1 ]; then
    echo "Restoring unstaged changes..."
    git stash pop --quiet
fi