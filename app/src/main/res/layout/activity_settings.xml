<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/yp_white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="@dimen/header_padding_top"
        android:paddingStart="@dimen/header_padding_start"
        android:paddingEnd="@dimen/header_padding_end"
        android:paddingBottom="@dimen/header_padding_bottom">

        <ImageView
            android:id="@+id/btnReturnFromSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_arrow_left"
            android:contentDescription="@string/settings" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/header_text_margin_start"
            android:text="@string/settings"
            android:textColor="@color/yp_black"
            android:fontFamily="@font/ys_display_medium"
            android:letterSpacing="0"
            android:textSize="@dimen/header_text_size" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="@dimen/content_margin_top">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="20dp"
            android:checked="true"
            android:text="@string/settings_dark_theme"
            android:textSize="16sp" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableEnd="@drawable/ic_share"
            android:paddingHorizontal="16dp"
            android:paddingVertical="20dp"
            android:text="@string/settings_share"
            android:textSize="16sp" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableEnd="@drawable/ic_support"
            android:paddingHorizontal="16dp"
            android:paddingVertical="20dp"
            android:text="@string/settings_support"
            android:textSize="16sp" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableEnd="@drawable/ic_arrow_forward"
            android:paddingHorizontal="16dp"
            android:paddingVertical="20dp"
            android:text="@string/settings_user_agreement"
            android:textSize="16sp" />

    </LinearLayout>
</LinearLayout>