<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/yp_white"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/header_padding_top"
        android:paddingBottom="@dimen/header_padding_bottom"
        app:navigationIcon="@drawable/ic_arrow_left"
        app:title="@string/settings"
        app:titleTextColor="@color/yp_black"
        app:titleTextAppearance="@style/SettingsToolbarTitle" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_margin_top"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/content_padding"
        android:paddingVertical="@dimen/settings_item_padding_vertical"
        android:checked="true"
        android:text="@string/settings_dark_theme"
        android:textSize="@dimen/settings_item_text_size" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableEnd="@drawable/ic_share"
        android:paddingHorizontal="@dimen/content_padding"
        android:paddingVertical="@dimen/settings_item_padding_vertical"
        android:text="@string/settings_share"
        android:textSize="@dimen/settings_item_text_size" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableEnd="@drawable/ic_support"
        android:paddingHorizontal="@dimen/content_padding"
        android:paddingVertical="@dimen/settings_item_padding_vertical"
        android:text="@string/settings_support"
        android:textSize="@dimen/settings_item_text_size" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableEnd="@drawable/ic_arrow_forward"
        android:paddingHorizontal="@dimen/content_padding"
        android:paddingVertical="@dimen/settings_item_padding_vertical"
        android:text="@string/settings_user_agreement"
        android:textSize="@dimen/settings_item_text_size" />
</LinearLayout>