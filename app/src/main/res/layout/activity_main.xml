<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/yp_blue"
    android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/header_padding_top"
            android:paddingStart="@dimen/header_padding_start"
            android:paddingEnd="@dimen/header_padding_end"
            android:paddingBottom="@dimen/header_padding_bottom"
            android:text="@string/playlist_maker"
            android:textColor="@color/yp_white"
            android:fontFamily="@font/ys_display_medium"
            android:letterSpacing="0"
            android:textSize="@dimen/header_text_size" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/content_padding">

            <Button
                android:id="@+id/btnSearch"
                style="@style/MainMenuButton"
                android:layout_marginBottom="@dimen/button_margin"
                android:text="@string/search"
                app:icon="@drawable/ic_search" />

            <Button
                android:id="@+id/btnMediaLibrary"
                style="@style/MainMenuButton"
                android:layout_marginTop="@dimen/button_margin"
                android:layout_marginBottom="@dimen/button_margin"
                android:text="@string/media_library"
                app:icon="@drawable/ic_media" />

            <Button
                android:id="@+id/btnSettings"
                style="@style/MainMenuButton"
                android:layout_marginTop="@dimen/button_margin"
                android:text="@string/settings"
                app:icon="@drawable/ic_settings" />

        </LinearLayout>
</LinearLayout>